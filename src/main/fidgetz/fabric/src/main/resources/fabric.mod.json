{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_author}"
  ],
  "license": "${license}",
  "environment": "client",
  "mixins": [
    {
      "config": "fidgetz.mixins.json",
      "environment": "client"
    },
    {
      "config": "fidgetz.fabric.mixins.json",
      "environment": "client"
    }
  ],
  "accessWidener": "fidgetz.accesswidener",
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": "${fabric_minecraft_version_range}",
    "java": ">=${java_version}",
    "fabric-api": "*"
  },
  "custom": {
    "modmenu": {
      "badges": [
        "library"
      ]
    }
  }
}